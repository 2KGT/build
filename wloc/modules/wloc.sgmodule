#!name=Sửa định vị Apple WLOC
#!desc=Sửa toạ độ trả về từ dịch vụ định vị mạng của Apple | Shortcuts (khuyên dùng): Đặt vị trí địa lý https://www.icloud.com/shortcuts/a82717d8fdad4e6280866fcf911173f7 Khôi phục vị trí thật https://www.icloud.com/shortcuts/f42632d406504f24a2cd163af4fe012f | Trang chọn điểm: https://wloc-pages.pages.dev/
#!author=Yu9191 Rewrite
#!homepage=https://github.com/2KGT/build/tree/main/wloc
#!category=Tools
#!arguments=Kinh độ:113.94114, Vĩ độ:22.544577, Độ chính xác:25, Cấp độ log:info
#!arguments-desc=Kinh độ/Vĩ độ: toạ độ mặc định (toạ độ đã lưu qua chọn điểm online sẽ được ưu tiên)\nĐộ chính xác: độ chính xác GPS (mét)\nCấp độ log: off/error/warn/info/debug/all\n\nCách dùng: mở trang chọn điểm -> chọn vị trí -> Lưu vào thiết bị

[Script]
Apple WLOC = type=http-response, pattern="^https?:\/\/gs-loc(-cn)?\.apple\.com\/clls\/wloc", requires-body=1, binary-body-mode=1, max-size=0, timeout=30, script-path=https://raw.githubusercontent.com/2KGT/build/refs/heads/main/wloc/dist/wloc.js, argument=longitude={{{Kinh độ}}}&latitude={{{Vĩ độ}}}&accuracy={{{Độ chính xác}}}&logLevel={{{Cấp độ log}}}
WLOC Settings = type=http-request, pattern="^https?:\/\/gs-loc(-cn)?\.apple\.com\/wloc-settings\/save", requires-body=0, max-size=0, timeout=10, script-path=https://raw.githubusercontent.com/2KGT/build/refs/heads/main/wloc/dist/wloc-settings.js

[MITM]
hostname = %APPEND% gs-loc.apple.com, gs-loc-cn.apple.com
